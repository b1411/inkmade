{
  "name": "inkmade",
  "private": true,
  "type": "module",
  "description": "INKMADE — B2C платформа кастомизации одежды с печатью по требованию",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "node --max-old-space-size=6144 node_modules/nuxt/bin/nuxt.mjs build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "icons": "node scripts/gen-icons.mjs",
    "logo": "node scripts/gen-logo.mjs",
    "hero": "node scripts/gen-hero.mjs",
    "media:optimize": "node scripts/optimize-generated-media.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rls": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "node node_modules/@playwright/test/cli.js test"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@imgly/background-removal": "^1.7.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.8.2",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/supabase": "^2.0.9",
    "@supabase/supabase-js": "^2.107.0",
    "@vueuse/core": "^14.3.0",
    "embla-carousel-vue": "^8.6.0",
    "gsap": "^3.15.0",
    "heic2any": "^0.0.4",
    "konva": "^10.3.0",
    "nuxt": "^4.4.7",
    "pdfjs-dist": "^6.1.200",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.35",
    "vue-konva": "^3.4.0",
    "vue-router": "^5.1.0",
    "vue-sonner": "^2.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/eslint": "^1.16.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6",
    "vue-tsc": "^3.3.5"
  }
}
