# Nuxt
.nuxt
.output
.data
dist
.nitro
.cache

# Зависимости
node_modules

# Логи
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Окружение и секреты (§3.8) — НЕ коммитить
.env
.env.*
!.env.example

# Редакторы / ОС
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json

# Supabase локально
supabase/.branches
supabase/.temp

.vercel

# Пакетный менеджер — используем pnpm; npm-lock не коммитим
package-lock.json

# Артефакты тестов Playwright
test-results/
playwright-report/
blob-report/

# Исходники фото/баннеров в корне — заливаются в Supabase Storage, в репо не нужны
/IMG*-orig.jpg
/баннер.jpg

# Мастера кадров для npm run hero (PNG в десятки МБ). В public их класть нельзя —
# Nuxt отдал бы их наружу; в git — тоже, он их не сожмёт. Отдаваемые AVIF/WebP
# в public/media/hero коммитятся, их и видит сайт.
/design/
