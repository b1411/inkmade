# INKMADE — переменные окружения (паспорт §3.8)
# Скопируй в .env и заполни. .env НЕ коммитится.
# Правило безопасности: SERVICE_ROLE_KEY и платёжные секреты — ТОЛЬКО серверный слой.

# ── Supabase ───────────────────────────────────────────────
NUXT_PUBLIC_SUPABASE_URL=          # публичный, в браузере
NUXT_PUBLIC_SUPABASE_ANON_KEY=     # публичный anon-ключ (под RLS)
SUPABASE_SERVICE_ROLE_KEY=         # СЕКРЕТ, только сервер (Nitro/Edge), обходит RLS

# ── Платёжный провайдер: Halyk ePay Invoice API ────────────
PAYMENT_PROVIDER=mock              # local: mock; staging/prod: epay. Production без epay fail-fast.
PAYMENT_WEBHOOK_SECRET=            # СЕКРЕТ callback URL. Сгенерировать: openssl rand -hex 32
EPAY_ENV=test                      # test | production
EPAY_CLIENT_ID=                    # OAuth client_id из кабинета Halyk ePay
EPAY_CLIENT_SECRET=                # СЕКРЕТ, только server runtime
EPAY_SHOP_ID=
EPAY_ACCOUNT_ID=
EPAY_TERMINAL_ID=                  # если выдан банком; нужен для части status/refund-конфигураций

# Онлайн-ККМ/ОФД — обязательна до включения production checkout
FISCAL_PROVIDER=
FISCAL_API_KEY=                    # СЕКРЕТ, только server runtime

# Ручные launch-gates: выставлять true только после фактической проверки
LEGAL_REVIEW_APPROVED=false
REAL_CONTENT_APPROVED=false

# ── AI-генерация принтов (fal.ai / Ideogram V3) — без ключа фича недоступна ──
# Включить: FEATURES.aiDesign=true в shared/config/features.ts + применить миграцию 0056.
FAL_KEY=                           # СЕКРЕТ, только сервер. https://fal.ai → API Keys
AI_IMAGE_PROVIDER=fal-ideogram     # пока единственный; задел под смену провайдера
AI_IMAGE_MODEL=fal-ai/ideogram/v3  # модель на fal.ai (Recraft/Flux — другой id)
AI_IMAGE_TIER=BALANCED             # TURBO | BALANCED | QUALITY (цена/качество)
AI_MONTHLY_QUOTA=5                 # бесплатных генераций в месяц на пользователя

# ── Прочее ─────────────────────────────────────────────────
NUXT_PUBLIC_SITE_URL=http://localhost:3000   # для share-ссылок и редиректов оплаты

# ── Аналитика и пиксели (§3.5.1) ───────────────────────────
NUXT_PUBLIC_META_PIXEL_ID=
NUXT_PUBLIC_TIKTOK_PIXEL_ID=
NUXT_PUBLIC_ANALYTICS_ID=

# ── Email-уведомления (Resend) — без ключа отправка отключена (no-op) ──
RESEND_API_KEY=                    # СЕКРЕТ, только сервер. https://resend.com → API Keys
RESEND_FROM=INKMADE <noreply@inkmade.kz>   # верифицированный домен-отправитель

# ── WhatsApp-уведомления (Meta Cloud API) — без ключей отключено (no-op) ──
WHATSAPP_TOKEN=                    # СЕКРЕТ, только сервер. Meta Cloud API access token
WHATSAPP_PHONE_ID=                 # id номера-отправителя WhatsApp Business

# ── Observability — пересылка серверных ошибок на webhook (Slack/Discord/любой) ──
# Без переменной ошибки только структурно логируются (в логи Vercel). С ней —
# дополнительно отправляются POST-уведомлением. НЕ обязательна.
ERROR_WEBHOOK_URL=
